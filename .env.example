# Oberon environment configuration.
# Copy to .env and adjust as needed. All values have working defaults.

# STAC catalog endpoint (Sentinel-2 L2A on Earth Search / Element84)
# OBERON_STAC_URL=https://earth-search.aws.element84.com/v1

# STAC API connection timeout (seconds)
# OBERON_STAC_TIMEOUT=30

# Max retry attempts for STAC failures
# OBERON_STAC_RETRIES=3

# GDAL HTTP timeout for COG reads (seconds)
# OBERON_COG_TIMEOUT=60

# GDAL HTTP max retries for COG reads
# OBERON_COG_RETRIES=3

# Logging format: "console" (human-readable, default) or "json" (structured, for containers)
# OBERON_LOG_FORMAT=console

# Disk cache directory for COG windows
# OBERON_CACHE_DIR=~/.cache/oberon

# --- Control plane (Rust server) ---

# Server bind address
# OBERON_BIND_ADDR=0.0.0.0:8000

# SQLite database path
# OBERON_DB_PATH=~/.oberon/oberon.db

# Python executable path (for pipeline subprocess)
# OBERON_PYTHON_PATH=python

# Disable API key auth for local dev (set to 1)
# OBERON_AUTH_DISABLED=1

# Rust logging verbosity (tracing convention)
# RUST_LOG=oberon_control_plane=info,tower_http=info
